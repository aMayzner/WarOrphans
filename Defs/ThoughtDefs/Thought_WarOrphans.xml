<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Memory thought: my parents died in the war -->
  <ThoughtDef>
    <defName>WarOrphans_ParentsDied</defName>
    <thoughtClass>Thought_Memory</thoughtClass>
    <durationDays>30</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>parents killed in war</label>
        <description>My parents were killed in the war. I'll never see them again.</description>
        <baseMoodEffect>-12</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>

  <!-- Social thought: bond from escaping war together (permanent) -->
  <ThoughtDef>
    <defName>WarOrphans_EscapedWarTogether</defName>
    <thoughtClass>Thought_MemorySocial</thoughtClass>
    <durationDays>3600</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>escaped war together</label>
        <description>We escaped the war together. That's a bond that doesn't break easily.</description>
        <baseOpinionOffset>25</baseOpinionOffset>
      </li>
    </stages>
  </ThoughtDef>

  <!-- Social thought: orphan grateful to rescuer (fading) -->
  <ThoughtDef>
    <defName>WarOrphans_RescuedMe</defName>
    <thoughtClass>Thought_MemorySocial</thoughtClass>
    <durationDays>60</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>rescued me from war</label>
        <description>They took me in when I had nowhere else to go. I owe them everything.</description>
        <baseOpinionOffset>20</baseOpinionOffset>
      </li>
    </stages>
  </ThoughtDef>

  <!-- Social thought: colonist feels good about rescuing orphan (fading) -->
  <ThoughtDef>
    <defName>WarOrphans_RescuedOrphan</defName>
    <thoughtClass>Thought_MemorySocial</thoughtClass>
    <durationDays>60</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>rescued war orphan</label>
        <description>We saved this child from the war. It feels right.</description>
        <baseOpinionOffset>15</baseOpinionOffset>
      </li>
    </stages>
  </ThoughtDef>

  <!-- Recovery milestones (triggered by HediffComp_RecoveryMilestones) -->
  <ThoughtDef>
    <defName>WarOrphans_Recovery_Improving</defName>
    <thoughtClass>Thought_Memory</thoughtClass>
    <durationDays>10</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>the nightmares are less frequent</label>
        <description>I still have bad dreams, but not every night anymore. Maybe things are getting better.</description>
        <baseMoodEffect>3</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>

  <ThoughtDef>
    <defName>WarOrphans_Recovery_FeelingSafer</defName>
    <thoughtClass>Thought_Memory</thoughtClass>
    <durationDays>15</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>starting to feel safe</label>
        <description>For the first time in a long time, I don't flinch at every loud noise. This place feels... safe.</description>
        <baseMoodEffect>6</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>

  <!-- Colony-wide mood penalty when rejecting orphans -->
  <ThoughtDef>
    <defName>WarOrphans_RejectedOrphans</defName>
    <thoughtClass>Thought_Memory</thoughtClass>
    <durationDays>10</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>we turned away war orphans</label>
        <description>We turned away children who had nowhere else to go. They might die because of us.</description>
        <baseMoodEffect>-5</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>

  <!-- Colony-wide mood boost when accepting orphans -->
  <ThoughtDef>
    <defName>WarOrphans_TookInOrphans</defName>
    <thoughtClass>Thought_Memory</thoughtClass>
    <durationDays>10</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>we took in war orphans</label>
        <description>We gave shelter to children who had nowhere else to go. That's something to be proud of.</description>
        <baseMoodEffect>5</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>

  <ThoughtDef>
    <defName>WarOrphans_Recovery_Healed</defName>
    <thoughtClass>Thought_Memory</thoughtClass>
    <durationDays>30</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>this place is home</label>
        <description>The war feels like a lifetime ago. I have a home now. I have people who care about me. I'm going to be okay.</description>
        <baseMoodEffect>10</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>
</Defs>
